rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().createdAt == request.time
        && incoming().uid == userId;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;
    }

    // Hubs
    match /hubs/{hubId} {
      allow read: if true; // Public marketplace access
      allow create: if isSignedIn()
        && incoming().ownerId == request.auth.uid
        && incoming().createdAt == request.time;
      allow update: if isSignedIn()
        && existing().ownerId == request.auth.uid
        && incoming().ownerId == existing().ownerId
        && (
          // Allow owner to update most fields except identity/stats
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'bannerImage', 'logoImage', 'categories', 'slug'])
          || (incoming().diff(existing()).affectedKeys().hasOnly(['totalRevenue']) && false) // Revenue updates strictly server-side (placeholders for now)
        );

      // Products subcollection
      match /products/{productId} {
        allow read: if true;
        allow write: if isSignedIn() && get(/databases/$(database)/documents/hubs/$(hubId)).data.ownerId == request.auth.uid;
      }

      // Messages subcollection
      match /messages/{messageId} {
        // Only allow reading messages if user has access to this hub (simplified for MVP: checking if membership exists)
        // For public hubs, maybe allow all. For now, strictly check membership.
        allow read: if isSignedIn(); 
        allow create: if isSignedIn()
          && incoming().authorId == request.auth.uid
          && incoming().createdAt == request.time
          && incoming().hubId == hubId;
      }
    }

    // User Access (Purchases)
    match /users/{userId}/access/{accessId} {
      allow read: if isOwner(userId);
      // Payouts/Access creation usually happens via server or strictly validated client flow.
      // For MVP, allow self-read but restrict modification.
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
